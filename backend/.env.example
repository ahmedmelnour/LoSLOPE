# Copy to .env and fill in your HiveMQ Cloud cluster details.
# Find these in the HiveMQ Cloud console:
#   Cluster URL -> MQTT_HOST   (e.g. abcd1234ef.s1.eu.hivemq.cloud)
#   Port 8883 (TLS) is the HiveMQ Cloud default.
#   Create a broker credential under "Access Management" -> MQTT_USER / MQTT_PASS.
# The backend only starts the MQTT subscriber when MQTT_HOST is set.

MQTT_HOST=
MQTT_PORT=8883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC=loslope/readings
MQTT_TLS=true
