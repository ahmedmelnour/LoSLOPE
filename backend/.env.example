# Copy to .env and fill in your HiveMQ Cloud cluster details.
# Find these in the HiveMQ Cloud console:
#   Cluster URL -> MQTT_HOST   (e.g. abcd1234ef.s1.eu.hivemq.cloud)
#   Port 8883 (TLS) is the HiveMQ Cloud default.
#   Create a broker credential under "Access Management" -> MQTT_USER / MQTT_PASS.
# The backend only starts the MQTT subscriber when MQTT_HOST is set.

MQTT_HOST=
MQTT_PORT=8883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC=loslope/readings
MQTT_TLS=true

# --- Alerting (Telegram + optional Gemini) ---
# Telegram: create a bot via @BotFather for the token; get the chat id from
# @userinfobot (or a group/channel id). Leave blank to just log alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Gemini (free tier) writes the alert text; blank = use the built-in template.
# Get a key at aistudio.google.com/apikey. Use a Flash model (high free quota).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Alert tuning: 2=WARNING, 3=CRITICAL; cooldown between repeat CRITICAL alerts.
ALERT_MIN_LEVEL=2
ALERT_COOLDOWN_SECONDS=120
